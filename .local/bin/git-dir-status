#!/bin/bash

BASE="$HOME/git"

# Colors
RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
BLUE="\033[0;34m"
RESET="\033[0m"

for dir in "$BASE"/*/*; do
    [ -d "$dir" ] || continue
    [ -d "$dir/.git" ] || continue

    echo -e "${YELLOW}=== $(basename "$dir") ===${RESET}"
    cd "$dir" || continue

    # Detect misconfigured remote
    if ! GIT_TERMINAL_PROMPT=0 git fetch --dry-run --quiet 2>/dev/null; then
        echo -e " ${RED}• Remote misconfigured or requires authentication${RESET}"
        echo
        continue
    fi

    git fetch --quiet

    # Uncommitted changes
    if ! git diff --quiet || ! git diff --cached --quiet; then
        echo -e " ${RED}• Uncommitted changes present${RESET}"
    fi

    # Untracked files
    if [ -n "$(git ls-files --others --exclude-standard)" ]; then
        echo -e " ${RED}• Untracked files present${RESET}"
    fi

    # Determine current branch
    branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)

    if [ "$branch" = "HEAD" ] || [ -z "$branch" ]; then
        echo -e " ${BLUE}• Detached HEAD or no branch — skipping push/pull checks${RESET}"
        echo
        continue
    fi

    # Determine upstream
    upstream=$(git rev-parse --abbrev-ref "$branch"@{upstream} 2>/dev/null)

    if [ -z "$upstream" ]; then
        echo -e " ${BLUE}• No upstream configured for branch '${branch}'${RESET}"
        echo
        continue
    fi

    # Check if upstream exists
    if ! git show-ref --verify --quiet "refs/remotes/$upstream"; then
        echo -e " ${RED}• Upstream branch '${upstream}' does not exist on remote${RESET}"
        echo
        continue
    fi

    # Commits to push
    if [ -n "$(git log --oneline "$upstream"..HEAD)" ]; then
        echo -e " ${RED}• Commits to push${RESET}"
        continue
    fi

    # Commits to pull
    if [ -n "$(git log --oneline HEAD.."$upstream")" ]; then
        echo -e " ${RED}• Commits to pull${RESET}"
        continue
    fi

    echo -e " ${GREEN}Nothing to commit, push, or pull${RESET}"
    echo
done

