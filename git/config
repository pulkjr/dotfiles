[alias]
	st = status
	ol = log --pretty=oneline
	olg = log --graph --decorate --pretty=oneline --abbrev-commit --all
[core]
	editor = vim
	pager = bat
	excludesFile = ~/.config/git/ignore
[init]
	defaultBranch = main
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[fetch]
	prune = true
[diff]
	algorithm = histogram
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[rerere]
	enabled = true
[branch]
	sort = -committerdate
[gpg]
	format = ssh
[gpg "ssh"]
	# Lists keys trusted for signature verification (git log --show-signature).
	# Format per line: "email@example.com ssh-ed25519 AAAA..."
	# Populated automatically by setup.sh alongside config.local.
	allowedSignersFile = ~/.config/git/allowed_signers
[commit]
	gpgsign = false

[include]
	path = ~/.config/git/config.local

[includeIf "gitdir:~/projects/work/"]
    path = ~/projects/work/.gitconfig

[includeIf "gitdir:~/projects/personal/"]
    path = ~/projects/personal/.gitconfig
[status]
	submoduleSummary = 1
